{
  "name": "@spectratools/graphic-designer-cli",
  "version": "0.14.2",
  "description": "Deterministic visual content generator — code screenshots, terminal shots, flowcharts, and infographics. No browser dependency.",
  "type": "module",
  "license": "MIT",
  "author": "spectra-the-bot",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "design": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "default": "./dist/renderer.js"
    },
    "./qa": {
      "types": "./dist/qa.d.ts",
      "default": "./dist/qa.js"
    },
    "./spec": {
      "types": "./dist/spec.schema.d.ts",
      "default": "./dist/spec.schema.js"
    },
    "./publish": {
      "types": "./dist/publish/index.d.ts",
      "default": "./dist/publish/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "pnpm --filter @spectratools/cli-shared run build && pnpm build"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "@spectratools/cli-shared": "workspace:*",
    "elkjs": "^0.11.0",
    "incur": "^0.3.0",
    "sharp": "^0.34.4",
    "shiki": "^4.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "files": ["dist", "fonts", "README.md"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "graphics",
    "infographics",
    "code-screenshot",
    "terminal-screenshot",
    "flowchart",
    "canvas",
    "carbon",
    "deterministic",
    "cli",
    "spectratools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spectra-the-bot/spectra-tools.git",
    "directory": "packages/graphic-designer"
  },
  "homepage": "https://github.com/spectra-the-bot/spectra-tools/tree/main/packages/graphic-designer#readme"
}
