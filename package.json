{
  "name": "spectra-tools",
  "private": true,
  "version": "0.0.0",
  "description": "Agent-friendly CLI tools for spectra-the-bot",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @spectratools/cli-shared run build && pnpm --filter @spectratools/tx-shared run build && tsc --noEmit -p tsconfig.base.json && pnpm -r run typecheck",
    "test": "vitest run",
    "test:docs": "node --test scripts/generate-docs.test.js scripts/validate-generated-docs.test.js scripts/check-custom-domain-assets.test.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "node scripts/generate-docs.js && vitepress build docs",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:validate": "node scripts/validate-generated-docs.js",
    "docs:check:custom-domain-assets": "node scripts/check-custom-domain-assets.js",
    "docs:ci": "pnpm docs:generate && pnpm docs:build && pnpm docs:validate && pnpm docs:check:custom-domain-assets",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm biome format --write packages/*/package.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
