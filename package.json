{
  "name": "spectra-tools",
  "private": true,
  "version": "0.0.0",
  "description": "Agent-friendly CLI tools for spectra-the-bot",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @spectratools/cli-shared run build && tsc --noEmit -p tsconfig.base.json && pnpm -r run typecheck",
    "test": "vitest run",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
